# ─── Firebase ────────────────────────────────────────────
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# Electron exe'de Google ile giriş için gerekli.
# Firebase Console → Authentication → Sign-in method → Google →
# "Web client ID" alanından kopyalanır (örn. 123456-abc.apps.googleusercontent.com).
# Google Cloud Console → APIs & Credentials → OAuth 2.0 Client → Authorized redirect URIs
# listesine şunu da ekleyin: http://localhost/google-oauth-callback
VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id

# ─── Cloudinary ──────────────────────────────────────────
# https://cloudinary.com/console adresinden alın
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_upload_preset

# ─── GitHub Actions Anlık Mail Tetikleme ─────────────────
# scripts/send-mail-outbox.mjs'yi periyodik değil, bir mail 'pending'
# olduğu an anlık tetiklemek için kullanılır (bkz. src/lib/mailOutbox.ts).
# ÖNEMLİ: Bu token build çıktısında herkese açık olur. Sadece bu repo'ya,
# sadece "Actions: Read and write" izniyle bir fine-grained PAT oluşturun,
# başka hiçbir izin vermeyin.
VITE_GITHUB_REPO=kullanici-adi/repo-adi
VITE_GITHUB_DISPATCH_TOKEN=your_fine_grained_github_pat
