rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() { return request.auth != null; }

    function isMember(orgId) {
      return isAuth() &&
        exists(/databases/$(database)/documents/orgMembers/$(orgId + '_' + request.auth.uid));
    }

    function getRole(orgId) {
      return get(/databases/$(database)/documents/orgMembers/$(orgId + '_' + request.auth.uid)).data.role;
    }

    function hasRole(orgId, role) {
      let roles = {
        'viewer': 1, 'staff': 2, 'admin': 3, 'owner': 4
      };
      return isMember(orgId) && roles[getRole(orgId)] >= roles[role];
    }

    // ─── Admin profilleri ─────────────────────────────────
    match /admins/{userId} {
      allow read: if isAuth() && request.auth.uid == userId;
      allow write: if isAuth() && request.auth.uid == userId;

      // Kişisel, proje (org) bazlı pano düzeni — sadece sahibi okuyup yazabilir
      match /orgDashboardPrefs/{orgId} {
        allow read, write: if isAuth() && request.auth.uid == userId;
      }
    }

    // ─── Kurumlar ─────────────────────────────────────────
    match /orgs/{orgId} {
      allow read: if isMember(orgId);
      allow create: if isAuth();
      allow update: if hasRole(orgId, 'admin');
      allow delete: if hasRole(orgId, 'owner');
    }

    // ─── Üyelik ───────────────────────────────────────────
    match /orgMembers/{memberId} {
      allow read: if isAuth() && (
        resource.data.uid == request.auth.uid ||
        isMember(resource.data.orgId)
      );
      // Bir kullanıcı kendini üye olarak ekleyebilir SADECE şu durumlarda:
      //  a) Yeni kurum kuruyorsa ve owner oluyorsa (createOrg akışı), VEYA
      //  b) inviteToken alanıyla işaret ettiği orgInvites/{token} dokümanı:
      //     - bu org'a ait, durumu 'pending', kendi e-postasına gönderilmiş,
      //     - ve eklediği rol o davetteki rolle birebir aynıysa (acceptInvite akışı).
      // Bu olmadan herhangi bir giriş yapmış kullanıcı, orgId'yi bilerek
      // doğrudan kendini istediği role ile herhangi bir kuruma ekleyebilirdi.
      allow create: if isAuth() && request.resource.data.uid == request.auth.uid &&
        memberId == request.resource.data.orgId + '_' + request.auth.uid && (
        (request.resource.data.role == 'owner' &&
          get(/databases/$(database)/documents/orgs/$(request.resource.data.orgId)).data.ownerId == request.auth.uid)
        ||
        (
          request.resource.data.inviteToken is string &&
          get(/databases/$(database)/documents/orgInvites/$(request.resource.data.inviteToken)).data.status == 'pending' &&
          get(/databases/$(database)/documents/orgInvites/$(request.resource.data.inviteToken)).data.orgId == request.resource.data.orgId &&
          get(/databases/$(database)/documents/orgInvites/$(request.resource.data.inviteToken)).data.role == request.resource.data.role &&
          get(/databases/$(database)/documents/orgInvites/$(request.resource.data.inviteToken)).data.email == request.auth.token.email.lower()
        )
      );
      allow update: if hasRole(resource.data.orgId, 'admin');
      allow delete: if hasRole(resource.data.orgId, 'admin') ||
                       request.auth.uid == resource.data.uid;
    }

    // ─── Davetler ─────────────────────────────────────────
    // Doküman ID'si artık davet token'ının kendisi (bkz. inviteMember/acceptInvite).
    // Bu sayede acceptInvite tarafında tekli getDoc kullanılabiliyor; query/list
    // ile email/orgId'ye bağlı koşullu read kuralları Firestore'da güvenilir
    // şekilde değerlendirilemiyordu (sonuç kümesinin TAMAMI için kanıtlanabilir
    // olmalı), bu yüzden davet kabul akışı "permission-denied" ile patlıyordu.
    match /orgInvites/{inviteId} {
      allow read: if isAuth() && (
        isMember(resource.data.orgId) ||
        resource.data.email == request.auth.token.email.lower()
      );
      allow create: if hasRole(request.resource.data.orgId, 'admin') &&
                       request.resource.data.token == inviteId;
      allow update: if isAuth() && (
        isMember(resource.data.orgId) ||
        resource.data.email == request.auth.token.email.lower()
      );
      allow delete: if hasRole(resource.data.orgId, 'admin');
    }

    // ─── Sürücüler ────────────────────────────────────────
    match /drivers/{driverId} {
      allow read: if isMember(resource.data.orgId);
      allow create: if hasRole(request.resource.data.orgId, 'staff');
      allow update: if hasRole(resource.data.orgId, 'staff');
      allow delete: if hasRole(resource.data.orgId, 'admin');
    }

    // ─── Araçlar ──────────────────────────────────────────
    match /vehicles/{vehicleId} {
      allow read: if isMember(resource.data.orgId);
      allow create: if hasRole(request.resource.data.orgId, 'staff');
      allow update: if hasRole(resource.data.orgId, 'staff');
      allow delete: if hasRole(resource.data.orgId, 'admin');
    }

    // ─── Aktivite günlüğü ─────────────────────────────────
    match /activityLogs/{logId} {
      allow read: if isMember(resource.data.orgId);
      allow create: if isMember(request.resource.data.orgId);
      allow update, delete: if hasRole(resource.data.orgId, 'admin');
    }

    // ─── Bildirimler ──────────────────────────────────────
    match /notifications/{notifId} {
      allow read, write: if isMember(resource.data.orgId);
      allow create: if isMember(request.resource.data.orgId);
    }

    // ─── E-posta Gönderim Kuyruğu (Outbox) ─────────────────
    // Giriş yapmış herhangi bir kullanıcı bir e-posta olayı (kayıt, davet,
    // çıkarma) tetiklendiğinde buraya yazabilir. Okuma/güncelleme/silme
    // sadece GitHub Actions'taki Firebase Admin SDK ile yapılır — Admin SDK
    // güvenlik kurallarını hiçe sayar, yani client tarafına read/write
    // vermemize gerek yok. Kullanıcılar başkalarının kuyruğunu okuyamaz/değiştiremez.
    match /mailOutbox/{mailId} {
      allow create: if request.auth != null;
      allow read, update, delete: if false;
    }

  }
}
